# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Worker (linkedin-login.js) — must match values in your Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
WORKSPACE_AES_SECRET=          # Exactly 32 ASCII chars — same value as in Supabase Edge Function env

# Optional: residential proxy for Playwright (leave blank to use direct connection)
RESIDENTIAL_PROXY_URL=

# Worker port (default: 3000)
PORT=3000
