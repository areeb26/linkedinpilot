# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend worker URL — all Unipile API calls are proxied through this
# so the API key is never exposed in the browser network tab.
VITE_BACKEND_URL=http://localhost:3000

# Worker (linkedin-login.js) — must match values in your Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
WORKSPACE_AES_SECRET=          # Exactly 32 ASCII chars — same value as in Supabase Edge Function env

# Optional: residential proxy for Playwright (leave blank to use direct connection)
RESIDENTIAL_PROXY_URL=

# Worker port (default: 3000)
PORT=3000

# ─── Unipile API ────────────────────────────────────────────────────────────────
# Get your DSN and API key from https://dashboard.unipile.com → Settings → API Keys
# NOTE: VITE_UNIPILE_DSN and VITE_UNIPILE_API_KEY are no longer used by the frontend.
# All Unipile calls go through the backend proxy. Only the backend vars below are needed.

# Backend (FastAPI worker) — used by backend/utils/unipile.py
UNIPILE_DSN=your-tenant.unipile.com             # e.g. api1.unipile.com:13465
UNIPILE_API_KEY=your_unipile_api_key_here       # Bearer token for Unipile REST API
