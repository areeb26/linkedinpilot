{
  "manifest_version": 3,
  "name": "LinkedIn Pilot Extension",
  "version": "1.1.1",
  "description": "LinkedIn automation extension",
  "author": "Antigravity",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["cookies", "storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://www.linkedin.com/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["contents/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["contents/linkedin.js"],
      "world": "ISOLATED",
      "all_frames": false,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "https://*.linkedpilot.ai/*"
      ],
      "js": ["contents/dashboard.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://*.linkedpilot.ai/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
